<!DOCTYPE html>
<html lang="en">
  <head>
    {{> boilerplate/head }}
  </head>
  <body>
    <header>
      {{> boilerplate/siteHeader }}
    </header>
    <main>
      <h2 class="page-header">
        <a href="/portfolio">Portfolio</a>
      </h2>
      
      <div class="project">
        
        {{> portfolio/projectHeader }}

        {{#if content}}
        <h3 id="project-description">Description</h3>
        
        <div aria-labelledby="project-description">
          {{{ content }}}
        </div>
        {{/if}}

        {{#if images}}
          <h3 id="project-images">Images</h3>
          <ul class="project-images" aria-labelledby="project-images">
          {{#each images}}
            <li><img src="{{this}}" data-image-index="{{@index}}" /></li>
          {{/each}}
          </ul>
        {{/if}}
        
      </div>
    </main>

    <dialog id="gallery-modal">
      <div class="modal-image-container">
        <img src="" alt="" />
      </div>
      <div class="modal-controls">
        <button class="modal-nav-btn modal-prev">← Previous</button>
        <span class="modal-counter"></span>
        <button class="modal-nav-btn modal-next">Next →</button>
        <button class="modal-close">Close</button>
      </div>
    </dialog>

    <script src="/js/gallery-modal.js"></script>
    {{> boilerplate/analytics }}
  </body>
</html>